# ===================================================================
# A comprehensive .gitignore file for a Python project.
# Lines starting with '#' are comments.
# ===================================================================

# Ignore environment variables file
.env

# Ignore node modules
node_modules

# Python virtual environment
.venv/
venv/

# Python cache
__pycache__/

# NiceGUI storage
.nicegui/

# VS Code specific
.vscode/

# Operating System files
.DS_Store

# Log, Debug, and Result Files
# These files change constantly and are specific to your local machine.
debug_model_output.txt
evaluation/results.json
*.log

# Ignore specific files that are frequently edited and not relevant for version control
reference/